{
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git push origin main)",
      "Bash(git branch*)",
      "Bash(git checkout *)",
      "Bash(git tag*)",
      "Bash(git ls-files*)",
      "Bash(git rev-parse*)",
      "Bash(git check-ignore *)",
      "Bash(git mv *)",
      "Bash(python -V)",
      "Bash(python --version)",
      "Bash(python -m pip list)",
      "Bash(python -m pip show *)",
      "Bash(python -m pip install -e .)",
      "Bash(python -m pip install -e .[*)",
      "Bash(python -m pip install -r requirements*.txt)",
      "Bash(python -c *)",
      "Bash(python -m py_compile *)",
      "Bash(python -m ruff *)",
      "Bash(python -m mypy *)",
      "Bash(.venv/bin/python *)",
      "Bash(ruff check *)",
      "Bash(ruff format *)",
      "Bash(mypy *)",
      "Bash(python main.py)",
      "Bash(python classify_demo.py)",
      "Bash(python train_cnn.py *)",
      "Bash(python tests/all_test.py)",
      "Bash(python tests/test_*.py)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(find *)",
      "Bash(echo *)",
      "Bash(pwd)",
      "Bash(date *)",
      "Bash(mkdir -p *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "mcp__sequential-thinking__*",
      "mcp__context7__*",
      "mcp__claude_ai_Context7__*",
      "mcp__filesystem__*",
      "mcp__git__*",
      "mcp__memory__*",
      "mcp__github__get_*",
      "mcp__github__list_*",
      "mcp__github__search_*",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:numpy.org)",
      "WebFetch(domain:scipy.org)",
      "WebFetch(domain:matplotlib.org)",
      "WebFetch(domain:pytorch.org)",
      "WebFetch(domain:rocm.docs.amd.com)",
      "WebFetch(domain:github.com)",
      "WebSearch"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)"
    ],
    "additionalDirectories": []
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre_bash.sh\"" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/post_write.sh\"" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/on_stop.sh\"" }
        ]
      }
    ]
  }
}
